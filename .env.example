# --- Runtime ---------------------------------------------------------------
VIBECHECK_ENV=development
VIBECHECK_LOG_LEVEL=INFO
VIBECHECK_DB=vibecheck.db

# --- Enrichment (LLM) ------------------------------------------------------
# Leave ANTHROPIC_API_KEY unset to use the deterministic mock enricher.
# ANTHROPIC_API_KEY=sk-ant-...
# VIBECHECK_ENRICHER=anthropic

# --- Embeddings ------------------------------------------------------------
# hashing (default, no deps) | sentence-transformers
VIBECHECK_EMBEDDINGS=hashing
VIBECHECK_EMBED_DIM=256

# --- Clustering ------------------------------------------------------------
VIBECHECK_CLUSTER_SIM=0.55
VIBECHECK_MIN_CLUSTER=3

# --- Queue / cache ---------------------------------------------------------
# memory (default) | celery
VIBECHECK_QUEUE=memory
REDIS_URL=redis://localhost:6379/0
VIBECHECK_CACHE=true

# --- Vector store ----------------------------------------------------------
# memory (default) | qdrant
VIBECHECK_VECTOR=memory
QDRANT_URL=http://localhost:6333

# --- Alert routing ---------------------------------------------------------
VIBECHECK_ALERT_SEV=4
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
# JIRA_URL=https://your-org.atlassian.net
